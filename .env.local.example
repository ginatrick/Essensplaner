# Kopieren nach .env.local und befüllen. .env.local NIE committen.
# Alles ohne NEXT_PUBLIC_ ist server-only (siehe docs/02-architektur.md, Sicherheitsprinzipien).

# --- Supabase (Projekt-Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Nur in Edge Functions / im Ingest-Prozess verwenden, nie im Client-Bundle.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic API (Zutaten-Parsing, Prospekt-Extraktion, Vorschlags-Begründung) ---
ANTHROPIC_API_KEY=

# --- Ingest-Service (lokal, aktuell Entwickler-PC, via Cloudflare Tunnel erreichbar) ---
INGEST_BASE_URL=https://<dein-tunnel>.trycloudflare.com
# Muss mit dem Secret übereinstimmen, das der Ingest-Service als X-Ingest-Secret erwartet.
INGEST_SHARED_SECRET=
